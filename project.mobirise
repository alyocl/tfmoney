                "&.opened": {
                  "height": "auto"
                }
              },
              ".nav-item .nav-link:hover::before": {
                "width": "175%",
                "max-width": "calc(100% ~\"+\" 2rem)",
                "left": "-1rem"
              }
            }
          },
          "_name": "menu3",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu3\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\" checked>\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"8\" step=\"0.1\" value=\"5\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\">\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\" checked>\n        <select title=\"Amount\" name=\"iconsAmount\" condition=\"showIcons\">\n            <option value=\"1\" selected>1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n        </select>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#000000\" condition=\"showIcons\">\n        <input type=\"checkbox\" title=\"Button\" name=\"showButtons\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.2\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color\" name=\"menuBgColor\" value=\"#bbbbbb\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#000000\">\n    </mbr-parameters>\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n            <div class=\"navbar-brand\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"index.html\"><img src=\"@PROJECT_PATH@/assets/images/blue20and20black20minimalist20brand20logo-429x429.webp\" alt=\"TF Money Logo\" mbr-style=\"{'height': logoSize + 'rem'}\"></a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-7\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove,-iconFont\"><a class=\"navbar-caption text-black\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">TF Money<br><br>香港主板上市公司附屬機構</a></span>\n            </div>\n            <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems || showIcons || showButtons\">\n                <div class=\"hamburger\">\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                    <span></span>\n                </div>\n            </button>\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\" mbr-if=\"showItems || showIcons || showButtons\">\n                <!-- 主選單：6項 -->\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-if=\"showItems\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><!-- 1. 首頁 -->\n                    \n\n                    <!-- 2. 關於我們 -->\n                    \n\n                    <!-- 3. 按揭產品（有子選單） -->\n                    <li class=\"nav-item\">\n                        <a class=\"nav-link link text-black text-primary\" href=\"about.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">關於我們</a>\n                    </li><li class=\"nav-item dropdown\">\n                        <a class=\"nav-link link text-black dropdown-toggle\" href=\"product.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"false\">按揭產品</a>\n                        <div class=\"dropdown-menu\" aria-labelledby=\"dropdown-product\">\n                            <a class=\"text-black dropdown-item\" href=\"product-introduction.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">按揭轉介</a>\n                            <a class=\"text-black dropdown-item\" href=\"product-second-mortgage.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">物業二按</a>\n                            <a class=\"text-black dropdown-item\" href=\"product-refinance.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">轉按套現</a>\n                            <a class=\"text-black dropdown-item\" href=\"product-parking.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">車位按揭</a>\n                            <a class=\"text-black dropdown-item\" href=\"product-hos.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">居屋業主貸款</a>\n                        </div>\n                    </li>\n\n                    <!-- 4. 知識中心（有子選單） -->\n                    <li class=\"nav-item dropdown\">\n                        <a class=\"nav-link link text-black dropdown-toggle show\" href=\"knowledge.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" data-toggle=\"dropdown-submenu\" data-bs-toggle=\"dropdown\" data-bs-auto-close=\"outside\" aria-expanded=\"false\">知識中心</a>\n                        <div class=\"dropdown-menu show\" aria-labelledby=\"dropdown-knowledge\" data-bs-popper=\"none\">\n                            <a class=\"text-black dropdown-item text-primary\" href=\"blog.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">按揭博客</a>\n                            <a class=\"text-black dropdown-item text-primary\" href=\"calculator.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">按揭計算機</a>\n                            <a class=\"text-black dropdown-item text-primary\" href=\"case-studies.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">個案研究</a>\n                            <a class=\"text-black dropdown-item text-primary\" href=\"testimonials.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">客戶心聲</a>\n                        </div>\n                    </li>\n\n                    <!-- 5. 常見問題 -->\n                    \n\n                    <!-- 6. 聯絡我們 -->\n                    <li class=\"nav-item\">\n                        <a class=\"nav-link link text-black text-primary\" href=\"faq.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">常見問題</a>\n                    </li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"contact.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">聯絡我們</a></li></ul>\n\n                <!-- WhatsApp Icon + 號碼 -->\n                <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://wa.me/99000000\" style=\"display: inline-flex; align-items: center; gap: 8px; text-decoration: none;\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-whatsapp socicon\" style=\"color: rgb(47, 145, 15); fill: rgb(47, 145, 15);\"></span>\n                        <span style=\"color: rgb(47, 145, 15); font-size: 20px;\">即時Whatsapp查詢</span>\n                    </a>\n                </div>\n\n                <!-- 其餘 Icon（可選，已保留原有結構） -->\n                <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                    <span mbr-icon class=\"p-2 mbr-iconfont mobi-mbri-video-play mobi-mbri\"></span>\n                </a>\n                <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                    <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                </a>\n                <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                    <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                </a>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_JSplaceholders": [],
          "_PHPplaceholders": [],
          "_isUserblock": true,
          "_cid": "vmSSnLVjzr",
          "_anchor": "menu3-3w",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            }
          },
          "_name": "header3",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header3\" group=\"Headers\" mbr-class=\"{'mbr-fullscreen': false}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"10\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"8\" step=\"1\">\n        <select title=\"Align\" name=\"contentAlign\">\n            <option value>Left</option>\n            <option value=\"justify-content-center\" selected>Center</option>\n            <option value=\"justify-content-end\">Right</option>\n        </select>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/mbr-6-1920x1280.jpg\" selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#802a87\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class=\"align-center\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row {{contentAlign}}\">\n            <div class=\"col-12 col-lg-{{textWidth}}\">\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-2\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\" style=\"text-align: center;\"><b>個案研究</b><b><br></b>\n                </h1>\n                <h2 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-5\" mbr-if=\"showSubitle\" style=\"text-align: center; font-weight: normal;\">參考案例 · 了解按揭解決方案</h2>\n                <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"display: none;\">&nbsp;</p>\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn mt-3\" mbr-if=\"showButtons\" style=\"display: none;\">\n                    <a class=\"btn btn-success\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Free Download!</a>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_cid": "vmSSnMVgxS",
          "_anchor": "header3-3x",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".item-wrapper": {
              "border-radius": "4px",
              "background": "@cardColor",
              "@media (min-width: 992px)": {
                "padding": "2rem"
              },
              "@media (max-width: 991px)": {
                "padding": "1rem",
                "margin-bottom": "2rem"
              }
            },
            ".row": {
              "align-items": "center",
              "justify-content": "center",
              ".row": {
                "@media (max-width: 767px)": {
                  "flex-direction": "column-reverse",
                  ".img-wrapper": {
                    "margin-bottom": "2rem"
                  }
                }
              }
            },
            ".img-wrapper img": {
              "width": "100%",
              "object-fit": "cover"
            },
            ".card-subtitle": {
              "color": "#0095ff"
            },
            ".mbr-text": {
              "color": "#555555"
            }
          },
          "_name": "features5",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features5\" group=\"Features\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" plugins=\"mobirise-icons2\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"6\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"6\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showsubTitle\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"color\" title=\"Card Color\" name=\"cardColor\" value=\"#fafafa\" condition=\"showLink\" selected>\n        <select title=\"Columns\" name=\"columns\">\n            <option value=\"3\">4</option>\n            <option value=\"4\">3</option>\n            <option value=\"6\" selected>2</option>\n            <option value=\"12\">1</option>\n        </select>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value selected>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\">\n            <input type=\"video\" title=\"Video\" value>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked style=\"display: none;\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\" style=\"display: none;\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\" style=\"display: none;\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\" style=\"display: none;\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n\n            <!-- ============================================================ -->\n            <!-- 案例 1：債務重組                                              -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年6月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>債務重組：月供 $52,158 降至 $8,699</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    方先生欠下巨債，信貸評級跌至 I 級（嚴重負面），透過物業二按成功重組債務。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image1-4v\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-406x270.webp\" alt=\"債務重組成功案例\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 2：自僱人士轉按                                          -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年5月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>自僱人士轉按，每月慳息 $2,500</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    自僱設計師收入不穩定，無固定入息證明，銀行拒批轉按，協助成功轉按慳息。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image2-4w\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-406x271.webp\" alt=\"自僱人士成功轉按\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 3：物業二按 24小時                                        -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年4月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>$50 萬周轉，24 小時批核</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    小生意東主急需 $50 萬資金周轉，銀行審批需時 4-6 星期，極速 24 小時完成。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image1-4x\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-504x504.webp\" alt=\"物業二按 24小時資金到手\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 4：居屋業主裝修貸款                                      -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年3月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>居屋裝修貸款 $30 萬，無需補地價</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    未補地價居屋業主需要資金裝修，部分銀行處理較審慎，度身訂造方案成功獲批。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image2-4y\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-1-406x610.webp\" alt=\"居屋業主裝修貸款\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 5：車位按揭套現                                          -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年2月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>車位按揭套現 $80 萬，還款期最長 15 年</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    客戶持有多個車位（市值約 $115 萬或以上），協助申請車位按揭，成功套現。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image1-4z\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-504x336.webp\" alt=\"車位按揭套現\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 6：首置人士 9 成按揭                                     -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2026年1月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>首置人士 9 成按揭，$40 萬首期上車</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    年輕首置人士儲蓄有限，協助申請按揭保險計劃，成功通過壓力測試及 DSR 要求。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image2-50\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-406x242.webp\" alt=\"首置人士 9成按揭上車\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 7：退休夫婦加按助兒子上車                                -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2025年12月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>退休夫婦加按套現 $200 萬，助兒子上車</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    退休夫婦想加按物業助兒子上車，銀行因年齡問題拒絕，安排兒子作擔保人成功獲批。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image1-53\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-1-406x271.webp\" alt=\"退休夫婦加按套現\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 8：村屋轉按清債套現                                      -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2025年11月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>村屋轉按清還高息債務，兼套現 $80 萬</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    村屋業主因 TU 信貸評級中下及收入不穩定被銀行拒絕，協助成功轉按，清還高息債務並套現。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image2-54\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-504x312.webp\" alt=\"村屋轉按清債套現\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 9：凶宅按揭成功批核                                      -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2025年10月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>凶宅按揭成功批核，$22 萬首期上會</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    客戶以低於市價 35% 購入事故單位，銀行拒批按揭，成功說服銀行以估價六成批核。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image1-55\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-406x325.webp\" alt=\"凶宅按揭成功批核\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ============================================================ -->\n            <!-- 案例 10：高齡人士以年輕擔保人獲 30 年按揭                    -->\n            <!-- ============================================================ -->\n            <div class=\"item features-without-image mb-4 col-12 col-md-{{columns}}\" style=\"display: flex; align-items: stretch;\">\n                <div class=\"item-wrapper\" style=\"width: 100%; min-height: 320px; display: flex; flex-direction: column; justify-content: space-between;\">\n                    <div class=\"row\" style=\"width: 100%; display: flex; justify-content: center; align-items: center;\">\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px;\">\n                            <div class=\"text-wrapper\" style=\"min-height: 180px;\">\n                                <h6 class=\"card-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-4\" mbr-if=\"showsubTitle\" data-app-selector=\".card-subtitle\" style=\"color: #888; font-size: 0.85rem;\">\n                                    📅 2025年9月\n                                </h6>\n                                <h5 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".card-title\" style=\"font-weight: 700; color: #1a2a6c; font-size: 1.2rem; min-height: 3.6rem;\">\n                                    <b>高齡人士以年輕擔保人獲 30 年按揭</b>\n                                </h5>\n                                <p class=\"mbr-text mbr-fonts-style mb-4\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\" style=\"font-size: 1rem; line-height: 1.6; color: #555; min-height: 3.2rem;\">\n                                    58 歲客戶因年齡問題還款期僅得 17 年，每月供款超出負擔。建議以 32 歲兒子作擔保人，成功延長還款期至 30 年。\n                                </p>\n                            </div>\n                            <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" style=\"margin-top: auto;\"><a href=\"case-post.html#image2-56\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\" style=\"border-radius: 50px; padding: 0.3rem 1.6rem; font-size: 0.9rem;\">了解更多 →</a></div>\n                        </div>\n                        <div class=\"col-12 col-md-6\" style=\"flex: 0 0 50%; max-width: 50%; padding: 0 15px; display: flex; justify-content: flex-end;\">\n                            <div class=\"img-wrapper\" style=\"width: 100%; height: 240px; overflow: hidden; border-radius: 12px;\">\n                                <img src=\"@PROJECT_PATH@/assets/images/mbr-2-406x271.webp\" alt=\"高齡人士以年輕擔保人獲30年按揭\" style=\"width: 100%; height: 100%; object-fit: cover; display: block;\">\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</section>",
