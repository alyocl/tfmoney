          "_name": "slider1",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"slider1\" group=\"Sliders & Galleries\" mbr-class=\"{'mbr-fullscreen': fullScreen}\">\n    <mbr-parameters>\n        <input type=\"id\" name=\"sliderId\">\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"!fullScreen\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"!fullScreen\">\n        <header>Carousel</header>\n        <input type=\"checkbox\" title=\"Fade Effect\" name=\"fade\">\n        <input type=\"checkbox\" title=\"Autoplay\" name=\"autoplay\" checked>\n        <input type=\"range\" title=\"Interval\" name=\"interval\" min=\"3\" max=\"10\" value=\"4\" step=\"1\" condition=\"autoplay\">\n        <header>Slide</header>\n        <input type=\"checkbox\" title=\"Caption\" name=\"showCaption\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#fafafa\" selected>\n    </mbr-parameters>\n    <div id=\"{{sliderId}}\" class=\"carousel slide\" mbr-class=\"{'carousel-fade': fade}\" data-ride=\"{{autoplay ? 'carousel' : false}}\" data-bs-ride=\"{{autoplay ? 'carousel' : false}}\" data-interval=\"{{interval*1000}}\" data-bs-interval=\"{{interval*1000}}\">\n        <ol class=\"carousel-indicators\">\n            <li data-target=\"#{{sliderId}}\" data-bs-target=\"#{{sliderId}}\" data-slide-to=\"0\" data-bs-slide-to=\"0\" class=\"active\"></li>\n            <li data-target=\"#{{sliderId}}\" data-bs-target=\"#{{sliderId}}\" data-slide-to=\"1\" data-bs-slide-to=\"1\"></li>\n        </ol>\n        <div class=\"carousel-inner\">\n\n <!-- ===== Slide 1：品牌定位 ===== -->\n<div class=\"carousel-item slider-image item active\">\n    <div class=\"item-wrapper\">\n        <img class=\"d-block w-100\" src=\"@PROJECT_PATH@/assets/images/pexels-komod-ayal-492320497-18093534-1920x1080.webp\" alt=\"上市公司集團成員 實力按揭專家\">\n        <div class=\"mbr-overlay\" mbr-if=\"overlay\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n        </div>\n        <div class=\"carousel-caption\" mbr-if=\"showCaption || showText\">\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showCaption\" mbr-theme-style=\"display-1\" data-app-selector=\".mbr-section-subtitle\">\n                <b>上市公司集團成員</b>\n            </h5>\n            <p class=\"mbr-section-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-2\" data-app-selector=\".mbr-section-text\">\n                <b>實力按揭專家</b>\n            </p>\n            <p class=\"mbr-section-description mbr-fonts-style\" style=\"font-size: 1.2rem; margin-top: 0.5rem;\">\n                按揭・轉介・慳息專家\n            </p>\n            <!-- 按鈕區域：加入 mbr-buttons 令 Mobirise 可編輯 -->\n            <div class=\"mbr-section-btn\" style=\"margin-top: 1.5rem;\" mbr-buttons mbr-theme-style=\"display-4\"><a class=\"btn btn-primary btn-lg\" href=\"https://wa.me/99000000\" data-app-selector=\".btn\" data-app-placeholder=\"Type Text\">立即免費諮詢</a>\n                <a class=\"btn btn-outline-light btn-lg\" href=\"product.html\" data-app-selector=\".btn\" data-app-placeholder=\"Type Text\">了解更多</a></div>\n            <p style=\"margin-top: 2rem; font-size: 0.9rem; opacity: 0.8;\">\n                ✔ 上市公司集團成員 ｜ ✔ 放債人牌照號碼 168/2026\n            </p>\n        </div>\n    </div>\n</div>\n\n<!-- ===== Slide 2：服務亮點 ===== -->\n<div class=\"carousel-item slider-image item\">\n    <div class=\"item-wrapper\">\n        <img class=\"d-block w-100\" src=\"@PROJECT_PATH@/assets/images/mbr-1280x791.webp\" alt=\"極速批核 靈活方案\">\n        <div class=\"mbr-overlay\" mbr-if=\"overlay\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n        </div>\n        <div class=\"carousel-caption\" mbr-if=\"showCaption || showText\">\n            <h5 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showCaption\" mbr-theme-style=\"display-1\" data-app-selector=\".mbr-section-subtitle\">\n                <b>極速批核</b>\n            </h5>\n            <p class=\"mbr-section-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-2\" data-app-selector=\".mbr-section-text\">\n                <b>24小時貸款到手</b>\n            </p>\n            <p class=\"mbr-section-description mbr-fonts-style\" style=\"font-size: 1.2rem; margin-top: 0.5rem;\">\n                靈活方案・自僱／無入息證明均可申請\n            </p>\n            <!-- 按鈕區域：加入 mbr-buttons 令 Mobirise 可編輯 -->\n            <div class=\"mbr-section-btn\" style=\"margin-top: 1.5rem;\" mbr-buttons mbr-theme-style=\"display-4\"><a class=\"btn btn-primary btn-lg\" href=\"contact.html\" data-app-selector=\".btn\" data-app-placeholder=\"Type Text\">立即免費諮詢</a>\n                <a class=\"btn btn-outline-light btn-lg\" href=\"product.html\" data-app-selector=\".btn\" data-app-placeholder=\"Type Text\">了解更多</a></div>\n            <p style=\"margin-top: 2rem; font-size: 0.9rem; opacity: 0.8;\">\n                ✔ 上市公司集團成員 ｜ ✔ 放債人牌照號碼 168/2026\n            </p>\n        </div>\n    </div>\n</div>\n\n        <a class=\"carousel-control carousel-control-prev\" href=\"#{{sliderId}}\" role=\"button\" data-slide=\"prev\" data-bs-slide=\"prev\">\n            <span class=\"mobi-mbri mobi-mbri-arrow-prev\" aria-hidden=\"true\"></span>\n            <span class=\"sr-only visually-hidden\">Previous</span>\n        </a>\n        <a class=\"carousel-control carousel-control-next\" href=\"#{{sliderId}}\" role=\"button\" data-slide=\"next\" data-bs-slide=\"next\">\n            <span class=\"mobi-mbri mobi-mbri-arrow-next\" aria-hidden=\"true\"></span>\n            <span class=\"sr-only visually-hidden\">Next</span>\n        </a>\n    </div>\n</div></section>",
          "_cid": "vjZKJsDune",
          "_anchor": "slider1-2",
          "_PHPplaceholders": [],
