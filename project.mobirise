            ".list": {
              "list-style": "none",
              "padding-left": "0",
              "@media (max-width: 991px)": {
                "margin-bottom": "2rem"
              },
              "@media (min-width: 992px)": {
                "margin-bottom": "0rem"
              },
              "color": "#bbbbbb"
            },
            ".mbr-text": {
              "color": "#bbbbbb"
            },
            ".soc-item": {
              "display": "flex",
              "align-items": "center",
              "justify-content": "center",
              "border-radius": "50%",
              "background-color": "white",
              "margin-right": "0.5rem",
              "margin-bottom": "1rem",
              "padding": "0.5rem",
              "height": "2.5rem",
              "width": "2.5rem"
            },
            ".mbr-iconfont": {
              "color": "black"
            },
            "@media (max-width: 991px)": {
              "div > *:last-child": {
                "margin-top": "0 !important"
              }
            }
          },
          "_name": "footer4",
          "_sourceTheme": "mobirise5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer4\" group=\"Footers\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\" global once=\"footers\">\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Logo Size\" name=\"logoSize\" min=\"1\" max=\"3\" step=\"1\" value=\"2\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\" checked>\n        <input type=\"range\" name=\"socialCount\" title=\"Social Count\" min=\"1\" max=\"4\" step=\"1\" value=\"3\" condition=\"showSocial\">\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopyright\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value>\n            <input type=\"color\" title=\"Color\" value=\"#bbbbbb\" selected>\n            <input type=\"video\" title=\"Video\" value>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" style=\"display: none;\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#232323\" condition=\"overlay && bg.type !== 'color'\" style=\"display: none;\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\" style=\"display: none;\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\" style=\"display: none;\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\">\n\n            <!-- ===== 欄位 1：Logo + 公司簡介 + Social（置頂） ===== -->\n            <div class=\"col-6 col-lg-3\" style=\"display: flex; flex-direction: column; align-items: center; justify-content: flex-start; text-align: center;\">\n\n                <div class=\"media-wrap\">\n                    <a href=\"index.html\">\n                        <img src=\"@PROJECT_PATH@/assets/images/blue20and20black20minimalist20brand20logo-429x429.webp\" alt=\"TF Money Logo\" style=\"width: 10rem; height: 10rem; object-fit: contain; display: block; margin: 0 auto;\">\n                    </a>\n                </div>\n\n                <p class=\"mbr-text mbr-fonts-style mt-2\" mbr-theme-style=\"display-7\" style=\"font-size: 0.85rem; color: #555; line-height: 1.5; margin-bottom: 0.8rem;\">\n                    上市公司集團成員<br>實力按揭專家\n                </p>\n\n                <!-- Social Icons -->\n                <div class=\"social-row display-7\" mbr-if=\"showSocial\" style=\"display: flex; gap: 12px; justify-content: center;\">\n                    <div class=\"soc-item\">\n                        <a href=\"https://www.facebook.com/yourpage\" target=\"_blank\" style=\"color: #333; font-size: 1.5rem;\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-facebook socicon\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>1\">\n                        <a href=\"https://www.instagram.com/yourpage\" target=\"_blank\" style=\"color: #333; font-size: 1.5rem;\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-instagram socicon\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>2\">\n                        <a href=\"https://www.youtube.com/yourchannel\" target=\"_blank\" style=\"color: #333; font-size: 1.5rem;\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-youtube socicon\"></span>\n                        </a>\n                    </div>\n                    <div class=\"soc-item\" mbr-if=\"socialCount>3\">\n                        <a href=\"https://wa.me/85299000000\" target=\"_blank\" style=\"color: #25D366; font-size: 1.5rem;\">\n                            <span mbr-icon class=\"mbr-iconfont socicon-whatsapp socicon\"></span>\n                        </a>\n                    </div>\n                </div>\n            </div>\n\n            <!-- ===== 欄位 2：公司資訊 ===== -->\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\" style=\"color: #1a2a6c; font-weight: 600;\">\n                    <b>公司資訊</b>\n                </h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline mbr-article style=\"padding-left: 0; list-style: none;\">\n                    <li class=\"mbr-text item-wrap\"><a href=\"about.html\" style=\"color: #333; text-decoration: none;\">關於我們</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"legal.html\" style=\"color: #333; text-decoration: none;\">法律與政策</a></li>\n                </ul>\n            </div>\n\n            <!-- ===== 欄位 3：按揭產品 ===== -->\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\" style=\"color: #1a2a6c; font-weight: 600;\">\n                    <b>按揭產品</b>\n                </h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline mbr-article style=\"padding-left: 0; list-style: none;\">\n                    <li class=\"mbr-text item-wrap\"><a href=\"product-introduction.html\" style=\"color: #333; text-decoration: none;\">按揭轉介</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"product-second-mortgage.html\" style=\"color: #333; text-decoration: none;\">物業二按</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"product-refinance.html\" style=\"color: #333; text-decoration: none;\">轉按套現</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"product-parking.html\" style=\"color: #333; text-decoration: none;\">車位按揭</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"product-hos.html\" style=\"color: #333; text-decoration: none;\">居屋業主貸款</a></li>\n                </ul>\n            </div>\n\n            <!-- ===== 欄位 4：知識中心 + 支援 ===== -->\n            <div class=\"col-12 col-md-6 col-lg-3\">\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\" style=\"color: #1a2a6c; font-weight: 600;\">\n                    <b>知識中心</b>\n                </h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline mbr-article style=\"padding-left: 0; list-style: none;\">\n                    <li class=\"mbr-text item-wrap\"><a href=\"blog.html\" style=\"color: #333; text-decoration: none;\">按揭博客</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"calculator.html\" style=\"color: #333; text-decoration: none;\">按揭計算機</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"case-studies.html\" style=\"color: #333; text-decoration: none;\">個案研究</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"testimonials.html\" style=\"color: #333; text-decoration: none;\" class=\"text-primary\">客戶心聲</a></li>\n                </ul>\n                <h5 class=\"mbr-section-subtitle mbr-fonts-style mb-2 mt-3\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle\" style=\"color: #1a2a6c; font-weight: 600;\">\n                    <b>支援</b>\n                </h5>\n                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list\" data-multiline mbr-article style=\"padding-left: 0; list-style: none;\">\n                    <li class=\"mbr-text item-wrap\"><a href=\"faq.html\" style=\"color: #333; text-decoration: none;\">常見問題</a></li>\n                    <li class=\"mbr-text item-wrap\"><a href=\"contact.html\" style=\"color: #333; text-decoration: none;\">聯絡我們</a></li>\n                </ul>\n            </div>\n\n            <!-- ===== 版權聲明 ===== -->\n            <div class=\"col-12 mt-4\" mbr-if=\"showCopyright\">\n                <hr style=\"border-color: rgba(0,0,0,0.08);\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style copyright align-center\" mbr-theme-style=\"display-7\" data-app-selector=\".copyright\" data-app-placeholder=\"Type Text\" style=\"font-size: 0.8rem; color: #999; text-align: center;\">\n                    © Copyright 2026 TF Money - All Rights Reserved<br>\n                    TF Money 為 TF Advances Limited 之品牌名稱（放債人牌照號碼：168/2026）<br>\n                    忠告: 借錢梗要還，咪俾錢中介，投訴熱線: 2111 0998\n                </p>\n            </div>\n\n        </div>\n    </div>\n</section>",
          "_cid": "vmV11Q5q3P",
          "_anchor": "footer4-4e",
